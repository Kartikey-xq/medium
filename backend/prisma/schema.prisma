generator client {
  provider   = "prisma-client-js"
  engineType = "edge"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String
  verified Boolean @default(false)

  posts         Post[]
  givenLikes    Like[]
  givenComments Comment[]
  givenSaves    Save[]
}

model Post {
  id          String   @id @default(uuid())
  title       String
  content     String
  description String
  published   Boolean  @default(false)
  imageUrl    String?
  viewCount   Int      @default(0)

  authorId   String
  authorName String
  author     User     @relation(fields: [authorId], references: [id])

  likes      Like[]
  comments   Comment[]
  saves      Save[]
  genres     Genre[]
  characters Character[]
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  blogId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [blogId], references: [id])

  @@unique([userId, blogId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  blogId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [blogId], references: [id])
}

model Save {
  id        String   @id @default(uuid())
  userId    String
  blogId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [blogId], references: [id])

  @@unique([userId, blogId])
}

model Genre {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[]
}

model Character {
  id     String  @id @default(uuid())
  name   String
  status String?
  bio    String?
  postId String
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

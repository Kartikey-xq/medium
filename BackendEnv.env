# ─── Backend Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env and fill in the values.
# This file is safe to commit. The actual .env is git-ignored.
#
# For production (Cloudflare Workers), set these as Wrangler secrets:
#   npx wrangler secret put JWT_SECRET
#   npx wrangler secret put DATABASE_URL

# PostgreSQL connection string.
# Use the POOLED URL from Neon or Supabase — Workers don't support persistent TCP.
# Neon format:    postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Supabase format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET=
